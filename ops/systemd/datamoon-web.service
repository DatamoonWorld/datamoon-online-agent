[Unit]
Description=Datamoons Online web portal
After=network-online.target datamoon-api.service
Wants=network-online.target
Requires=datamoon-api.service

[Service]
Type=simple
User=datamoon-web
Group=datamoon-web
WorkingDirectory=/opt/datamoon/datamoon-online-web
EnvironmentFile=/opt/datamoon/env/datamoon-web.env
EnvironmentFile=/opt/datamoon/env/datamoon-web-secrets.env
ExecStart=/usr/bin/node /opt/datamoon/datamoon-online-web/src/app.js
Restart=on-failure
RestartSec=3
TimeoutStopSec=20
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
PrivateDevices=true
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectKernelLogs=true
ProtectControlGroups=true
ProtectProc=invisible
ProcSubset=pid
RestrictSUIDSGID=true
RestrictRealtime=true
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6
LockPersonality=true
SystemCallArchitectures=native
UMask=0077
CapabilityBoundingSet=
AmbientCapabilities=
IPAddressDeny=any
IPAddressAllow=localhost
ReadWritePaths=/var/lib/datamoon-web
StateDirectory=datamoon-web
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
